# Bandit Security Configuration (TOML format)
# See: https://bandit.readthedocs.io/en/latest/config.html

[bandit]

# Exclude patterns - files and directories to skip
exclude = [
    "tests",
    "benchmark/.data",
    ".bench-repos",
    ".venv",
    "*/test_*.py",
    "*/*_test.py",
]

# B101: assert_used - Allow assert in test files
# Rationale: Assertions are standard in test code and serve as runtime validation
assert_used:
    skips = ["*/test_*.py", "*/*_test.py"]

# B404: import_subprocess - Allow subprocess import
# This is handled via # nosec annotation in grid.py
# Rationale: subprocess is used to orchestrate parallel benchmark trials safely

# B603: subprocess_without_shell_true - Allow subprocess.run without shell
# This is handled via # nosec annotation in grid.py
# Rationale: Commands are internally generated, not from user input
#           cwd is controlled, env is derived from safe os.environ copy
